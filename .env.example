"""Environment configuration file template."""
# Copy to .env and fill in your values

# Application
DEBUG=True
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# Environment configuration file template.
# Copy to .env and fill in your values

# Application
DEBUG=True

# Database
DATABASE_URL=sqlite:///./agent_lock.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/agent_lock

# Auth0
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
# Optional: set this only when your Auth0 client supports password-realm grant.
AUTH0_REALM=
ALLOW_MOCK_AUTH=False
LOCAL_PASSWORD_LOGIN_FALLBACK=True
AUTH0_REQUEST_TIMEOUT_SECONDS=10

# JWT
SECRET_KEY=<your-secret-key>